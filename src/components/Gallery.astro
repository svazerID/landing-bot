---
const { node } = Astro.props;
import { urlFor } from '../utils/sanity';

const images = node.images || [];
---

<div class="magazine-gallery">
  {images.map((img: any) => (
    <img src={urlFor(img).url()} alt="Gallery Image" loading="lazy" />
  ))}
</div>

<style>
  .magazine-gallery {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1rem;
    margin: 2rem 0;
  }
  .magazine-gallery img {
    border-radius: 8px;
    width: 100%;
    height: auto;
    object-fit: cover;
  }
</style>
