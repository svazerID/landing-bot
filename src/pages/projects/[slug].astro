---
export const prerender = false;
import MagazineLayout from '../../layouts/MagazineLayout.astro';
import PortableText from '../../components/PortableText.astro';
import { sanityClient, urlFor } from '../../utils/sanity';

const { slug } = Astro.params;
let project = null;
let allProjects = [];

try {
  [project, allProjects] = await Promise.all([
    sanityClient.fetch(`*[_type == "project" && slug.current == $slug][0]`, { slug }),
    sanityClient.fetch(`*[_type == "project"] | order(order asc)`)
  ]);
} catch (error) {
  console.error("Failed to fetch project data:", error);
}

// Override with static data for bot portfolio
allProjects = [
  {
    title: "Takina MD",
    description: "A comprehensive WhatsApp Multi-Device bot with 508+ plugins covering AI chat, media downloading, RPG games, and group management. Powered by Baileys & Node.js.",
    slug: { current: "takina-md" },
    projectUrl: "https://chat.whatsapp.com/Jmol4sl3VGA6f5gjmExkWK",
    themeHex: "#1a0f30",
    device: "iphone",
    homepageImage: "https://cdn.svazer.eu.cc/file/17914866.jpg"
  },
  {
    title: "Sewa Bot System",
    description: "An automated rental bot system allowing users to rent bot instances. Features include auto-expiration, payment integration, and isolated databases.",
    slug: { current: "sewa-bot" },
    projectUrl: "https://takina.svazer.eu.cc",
    themeHex: "#121f1a",
    device: "browser",
    homepageImage: "https://cdn.svazer.eu.cc/file/eb88baf2.jpg"
  },
  {
    title: "Jadibot Engine",
    description: "A cloning engine that enables users to connect their own WhatsApp numbers to the bot. Features independent sessions with a shared persistent SQLite database.",
    slug: { current: "jadibot-engine" },
    projectUrl: "https://jadibot-nih-bang.vercel.app",
    themeHex: "#300a0a",
    device: "browser",
    homepageImage: "https://cdn.svazer.eu.cc/file/80452622.jpeg"
  },
  {
    title: "Alsya API",
    description: "Layanan REST API komprehensif yang menyediakan berbagai endpoint handal untuk bot dan web. Dirancang untuk performa tinggi dan uptime maksimal.",
    slug: { current: "alsya-api" },
    projectUrl: "https://api.alfisy.my.id",
    themeHex: "#0f1a30",
    device: "browser",
    homepageImage: "https://cdn.svazer.eu.cc/file/9fda3fbb.jpeg"
  },
  {
    title: "Svazer CDN",
    description: "Content Delivery Network (CDN) yang cepat dan andal untuk upload file dan hosting media. Solusi ideal untuk penyimpanan file yang aman dan mudah diakses.",
    slug: { current: "svazer-cdn" },
    projectUrl: "https://cdn.svazer.eu.cc",
    themeHex: "#2a0a30",
    device: "browser",
    homepageImage: "https://cdn.svazer.eu.cc/file/39699610.jpeg"
  }
];

project = allProjects.find((p: any) => p.slug.current === slug) || null;
if (project) {
  project.role = "Lead Developer";
  project.year = "2024";
  project.stack = "Node.js, Baileys, SQLite";
  project.status = "Active";
  project.pageHeroImage = project.homepageImage;
  
  if (project.slug.current === 'takina-md') {
    project.bodyRaw = "<p>Takina MD adalah sebuah bot WhatsApp canggih berbasis Multi-Device yang dirancang untuk skalabilitas dan performa tinggi. Dibangun menggunakan framework <strong>Baileys</strong> dan <strong>Node.js</strong>, bot ini memiliki arsitektur modular yang mendukung lebih dari 500+ plugin interaktif.</p><br/><p>Fitur utama meliputi integrasi dengan 43+ model AI, sistem RPG game yang imersif, manajemen grup otomatis, dan berbagai alat utilitas lainnya. Data disimpan menggunakan SQLite dengan mode WAL untuk menjamin stabilitas dan kecepatan tinggi bahkan saat trafik padat.</p>";
  } else if (project.slug.current === 'sewa-bot') {
    project.bodyRaw = "<p>Sewa Bot System adalah platform otomasi penyewaan bot WhatsApp yang memungkinkan pengguna untuk menyewa <em>instance</em> bot secara mandiri.</p><br/><p>Sistem ini dirancang dengan fitur <em>auto-expiration</em>, integrasi <em>payment gateway</em>, dan manajemen database terisolasi untuk masing-masing penyewa. Ini memastikan keamanan data privasi dan memberikan pengalaman operasional yang lepas tangan (hands-free) bagi admin.</p>";
  } else if (project.slug.current === 'jadibot-engine') {
    project.bodyRaw = "<p>Jadibot Engine adalah sistem kloning inovatif yang memungkinkan pengguna menghubungkan nomor WhatsApp mereka sendiri ke dalam bot (menjadikan nomor mereka bot sementara).</p><br/><p>Setiap sesi kloning berjalan secara independen namun tetap dapat berbagi sumber daya dari database SQLite pusat. Fitur ini sangat berguna untuk pengguna yang ingin merasakan memiliki bot sendiri tanpa harus mengatur server, hosting, maupun dependensi teknis lainnya.</p>";
  } else if (project.slug.current === 'alsya-api') {
    project.bodyRaw = "<p>Alsya API adalah layanan REST API komprehensif yang dirancang untuk mendukung ekosistem bot WhatsApp dan aplikasi web. Dengan infrastruktur yang kuat, API ini menyediakan berbagai endpoint penting mulai dari utilitas data hingga pemrosesan media.</p><br/><p>Fokus utama layanan ini adalah memberikan respons berkecepatan tinggi (low latency) dengan jaminan uptime yang stabil, memudahkan developer lain untuk membangun fitur tanpa harus mengelola backend kompleks sendiri.</p>";
  } else if (project.slug.current === 'svazer-cdn') {
    project.bodyRaw = "<p>Svazer CDN adalah sistem Content Delivery Network dan platform manajemen file yang dirancang untuk kecepatan dan efisiensi. Sangat cocok digunakan untuk meng-hosting gambar, dokumen, dan media lainnya yang di-generate oleh bot.</p><br/><p>Sistem ini memberikan pengalaman upload yang mulus dengan antarmuka yang ramah pengguna, serta menjamin aset media Anda dapat diakses dengan cepat dari mana saja tanpa membebani server utama bot.</p>";
  }
}

if (!project) {
  return Astro.redirect('/404');
}

const currentIndex = allProjects.findIndex((p: any) => p.slug.current === slug);
const nextProject = allProjects.length > 0 ? allProjects[(currentIndex + 1) % allProjects.length] : null;

const colors = ['#1a0f30', '#121f1a', '#300a0a'];
const projectColors: Record<string, string> = {
  'the-retro-circuit': '#1a0f30',
  'setlists-md': '#121f1a',
  'setlist-md': '#121f1a', // Fallback for either slug spelling
  'redline-running': '#300a0a'
};

const projectBgColor = project.themeHex || projectColors[project.slug.current] || colors[currentIndex % colors.length];
---

<MagazineLayout title={project.title} description={project.description} backgroundColor={projectBgColor}>
  {project.pageHeroImage && (
    <div class="project-hero-wrapper">
      <img src={typeof project.pageHeroImage === 'string' ? project.pageHeroImage : urlFor(project.pageHeroImage).url()} alt={project.title} class="project-hero-img" />
    </div>
  )}

  <article class="article-layout">
    <header class="article-header">
      <h1 class="article-title">{project.title}</h1>
      <div class="article-meta-grid">
        <div class="meta-item">
          <span class="meta-label">ROLE</span>
          <span class="meta-value">{project.role || 'N/A'}</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">YEAR</span>
          <span class="meta-value">{project.year || 'N/A'}</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">STACK</span>
          <span class="meta-value">{project.stack || 'N/A'}</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">STATUS</span>
          <span class="meta-value">{project.status || 'N/A'}</span>
        </div>
      </div>
    </header>

    <section class="article-body">
      {project.bodyRaw ? <div class="project-custom-body" set:html={project.bodyRaw} style="font-size: 1.1rem; line-height: 1.6; color: var(--accents-8);" /> : (project.body ? <PortableText portableText={project.body} /> : <p>No content available.</p>)}
    </section>

    {nextProject && (
      <footer class="magazine-footer-nav">
        <a href={`/projects/${nextProject.slug.current}`} class="footer-nav-link" data-hover style="text-align: right; width: 100%;">
          <span class="nav-label">NEXT PROJECT</span>
          {nextProject.title}
        </a>
      </footer>
    )}
    <a href="/#top" class="footer-back-studio" data-hover>&larr; Back to Studio Index</a>
  </article>
</MagazineLayout>
