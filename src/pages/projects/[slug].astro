---
export const prerender = false;
import MagazineLayout from '../../layouts/MagazineLayout.astro';
import PortableText from '../../components/PortableText.astro';
import { sanityClient, urlFor } from '../../utils/sanity';

const { slug } = Astro.params;
let project = null;
let allProjects = [];

try {
  [project, allProjects] = await Promise.all([
    sanityClient.fetch(`*[_type == "project" && slug.current == $slug][0]`, { slug }),
    sanityClient.fetch(`*[_type == "project"] | order(order asc)`)
  ]);
} catch (error) {
  console.error("Failed to fetch project data:", error);
}

// Override with static data for bot portfolio
allProjects = [
  {
    title: "Takina MD",
    description: "A comprehensive WhatsApp Multi-Device bot with 508+ plugins covering AI chat, media downloading, RPG games, and group management. Powered by Baileys & Node.js.",
    slug: { current: "takina-md" },
    projectUrl: "https://chat.whatsapp.com/Jmol4sl3VGA6f5gjmExkWK",
    themeHex: "#1a0f30",
    device: "iphone",
    homepageImage: "https://cdn.svazer.eu.cc/file/59d11ba1.jpeg"
  },
  {
    title: "Sewa Bot System",
    description: "An automated rental bot system allowing users to rent bot instances. Features include auto-expiration, payment integration, and isolated databases.",
    slug: { current: "sewa-bot" },
    projectUrl: "https://takina.svazer.eu.cc",
    themeHex: "#121f1a",
    device: "browser",
    homepageImage: "https://cdn.svazer.eu.cc/file/eb88baf2.jpg"
  },
  {
    title: "Jadibot Engine",
    description: "A cloning engine that enables users to connect their own WhatsApp numbers to the bot. Features independent sessions with a shared persistent SQLite database.",
    slug: { current: "jadibot-engine" },
    projectUrl: "https://jadibot-nih-bang.vercel.app",
    themeHex: "#300a0a",
    device: "browser",
    homepageImage: "https://cdn.svazer.eu.cc/file/80452622.jpeg"
  },
  {
    title: "Alsya API",
    description: "A robust REST API service providing reliable endpoints for bots and web applications. Built for high performance and maximum uptime.",
    slug: { current: "alsya-api" },
    projectUrl: "https://api.alfisy.my.id",
    themeHex: "#0f1a30",
    device: "browser",
    homepageImage: "https://cdn.svazer.eu.cc/file/ab7ee814.jpeg"
  },
  {
    title: "Svazer CDN",
    description: "A lightning-fast Content Delivery Network tailored for media hosting and seamless file uploads. Designed to ensure secure and instant access.",
    slug: { current: "svazer-cdn" },
    projectUrl: "https://cdn.svazer.eu.cc",
    themeHex: "#2a0a30",
    device: "browser",
    homepageImage: "https://cdn.svazer.eu.cc/file/39699610.jpeg"
  },
  {
    title: "Alfixd AI",
    description: "An advanced multimodal chatbot assistant integrating 10+ top-tier AI models. Built with a modern interface for text, image, and voice processing.",
    slug: { current: "alfixd-ai" },
    projectUrl: "https://ai.alfisy.my.id",
    themeHex: "#0a1828",
    device: "iphone",
    homepageImage: "https://cdn.svazer.eu.cc/file/df5f8ebb.jpeg"
  },
  {
    title: "Axd Downloader",
    description: "An all-in-one centralized downloading platform to easily save videos, images, and audio from various social media networks.",
    slug: { current: "axd-downloader" },
    projectUrl: "https://vdl.alfisy.my.id",
    themeHex: "#2d1b11",
    device: "iphone",
    homepageImage: "https://cdn.svazer.eu.cc/file/2eb69fe5.jpeg"
  },
  {
    title: "Axd Player",
    description: "A sleek, modern web music player offering premium streaming experiences. Search YouTube tracks, play instantly, and download high-quality MP3s.",
    slug: { current: "axd-player" },
    projectUrl: "https://play.alfisy.my.id/",
    themeHex: "#1c0d22",
    device: "iphone",
    homepageImage: "https://cdn.svazer.eu.cc/file/53d877b4.jpeg"
  },
  {
    title: "Alfixd Image Tools",
    description: "An AI-powered image editing studio featuring one-click Image Upscaling, Automatic Background Removal, and Creative AI Prompt Editing.",
    slug: { current: "alfixd-image-tools" },
    projectUrl: "https://img-tool.alfisy.my.id",
    themeHex: "#0e221c",
    device: "browser",
    homepageImage: "https://cdn.svazer.eu.cc/file/1cb492aa.jpeg"
  }
];

project = allProjects.find((p: any) => p.slug.current === slug) || null;
if (project) {
  project.role = "Lead Developer";
  project.year = "2024";
  project.stack = "Node.js, Baileys, SQLite";
  project.status = "Active";
  project.pageHeroImage = project.homepageImage;
  
  if (project.slug.current === 'takina-md') {
    project.bodyRaw = "<p>Takina MD is an advanced WhatsApp Multi-Device bot architected for ultimate scalability and high performance. Built on top of the <strong>Baileys</strong> framework and <strong>Node.js</strong>, it boasts a modular architecture supporting over 500+ interactive plugins.</p><br/><p>Core features include seamless integration with 43+ AI models, an immersive RPG gaming system, automated group management, and versatile utility tools. Data is securely managed using SQLite with WAL mode, ensuring stability and blazing-fast response times even under heavy traffic.</p>";
  } else if (project.slug.current === 'sewa-bot') {
    project.bodyRaw = "<p>The Sewa Bot System is an automated WhatsApp bot rental platform that empowers users to easily deploy and rent their own bot instances independently.</p><br/><p>The system is engineered with auto-expiration tracking, seamless payment gateway integration, and isolated database management for each tenant. This architecture guarantees data privacy and provides a completely hands-free operational experience for the administrator.</p>";
  } else if (project.slug.current === 'jadibot-engine') {
    project.bodyRaw = "<p>Jadibot Engine is an innovative session-cloning system that allows users to link their personal WhatsApp numbers to the bot ecosystem, temporarily transforming their accounts into functioning bots.</p><br/><p>Every cloned session operates independently while intelligently sharing resources from a centralized SQLite database. This feature is perfect for users who want to experience owning a bot without the hassle of server configuration, hosting, or technical dependencies.</p>";
  } else if (project.slug.current === 'alsya-api') {
    project.bodyRaw = "<p>Alsya API is a comprehensive REST API service specifically designed to power WhatsApp bot ecosystems and modern web applications. Backed by robust infrastructure, it provides essential endpoints ranging from data utilities to intensive media processing.</p><br/><p>The primary focus of this service is delivering ultra-low latency responses with rock-solid uptime guarantees, enabling developers to build sophisticated features without the burden of managing complex backend systems.</p>";
  } else if (project.slug.current === 'svazer-cdn') {
    project.bodyRaw = "<p>Svazer CDN is a lightning-fast Content Delivery Network and file management platform engineered for speed and efficiency. It serves as the ideal hosting solution for images, documents, and other media assets generated by the bots.</p><br/><p>The system provides a frictionless uploading experience with a user-friendly interface, ensuring your media assets are instantly accessible globally without straining the primary bot servers.</p>";
  } else if (project.slug.current === 'alfixd-ai') {
    project.bodyRaw = "<p>Alfixd AI is an advanced multimodal chatbot assistant designed to process a wide variety of instructions with absolute precision. The platform proudly integrates over 10 of the industry's most cutting-edge AI models.</p><br/><p>Featuring a sleek, highly responsive interface, the application goes beyond simple text generation—it excels in intelligent image processing, voice recognition, and efficient document analysis, offering a truly next-generation AI experience.</p>";
  } else if (project.slug.current === 'axd-downloader') {
    project.bodyRaw = "<p>Axd Downloader is an <em>all-in-one</em> utility platform that streamlines the process of downloading digital assets across various social media networks. It is the ultimate practical solution for archiving your favorite online content.</p><br/><p>Powered by a robust backend system, the application rapidly processes and securely downloads videos, images, and audio in multiple resolutions without any frustrating limitations or paywalls.</p>";
  } else if (project.slug.current === 'axd-player') {
    project.bodyRaw = "<p>AXD Player is a modern web-based music application that delivers a premium audio streaming experience directly from your browser, completely eliminating the need for third-party software installations.</p><br/><p>Users can effortlessly search the massive YouTube directory, play tracks instantly via an elegant player interface, and download high-quality MP3 files to enjoy their favorite music offline.</p>";
  } else if (project.slug.current === 'alfixd-image-tools') {
    project.bodyRaw = "<p>Alfixd Image Tools is a comprehensive visual editing studio powered by Artificial Intelligence, designed to dramatically accelerate your creative workflow.</p><br/><p>The platform offers state-of-the-art features such as <strong>Image Upscaling</strong> to enhance resolution without losing quality, highly accurate automatic <strong>Background Removal</strong>, and <strong>AI Prompt Editing</strong>, which allows you to transform the style and composition of your images using simple, creative text commands.</p>";
  }
}

if (!project) {
  return Astro.redirect('/404');
}

const currentIndex = allProjects.findIndex((p: any) => p.slug.current === slug);
const nextProject = allProjects.length > 0 ? allProjects[(currentIndex + 1) % allProjects.length] : null;

const colors = ['#1a0f30', '#121f1a', '#300a0a'];
const projectColors: Record<string, string> = {
  'the-retro-circuit': '#1a0f30',
  'setlists-md': '#121f1a',
  'setlist-md': '#121f1a', // Fallback for either slug spelling
  'redline-running': '#300a0a'
};

const projectBgColor = project.themeHex || projectColors[project.slug.current] || colors[currentIndex % colors.length];
---

<MagazineLayout title={project.title} description={project.description} backgroundColor={projectBgColor}>
  {project.pageHeroImage && (
    <div class="project-hero-wrapper">
      <img src={typeof project.pageHeroImage === 'string' ? project.pageHeroImage : urlFor(project.pageHeroImage).url()} alt={project.title} class="project-hero-img" />
    </div>
  )}

  <article class="article-layout">
    <header class="article-header">
      <h1 class="article-title">{project.title}</h1>
      <div class="article-meta-grid">
        <div class="meta-item">
          <span class="meta-label">ROLE</span>
          <span class="meta-value">{project.role || 'N/A'}</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">YEAR</span>
          <span class="meta-value">{project.year || 'N/A'}</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">STACK</span>
          <span class="meta-value">{project.stack || 'N/A'}</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">STATUS</span>
          <span class="meta-value">{project.status || 'N/A'}</span>
        </div>
      </div>
    </header>

    <section class="article-body">
      {project.bodyRaw ? <div class="project-custom-body" set:html={project.bodyRaw} style="font-size: 1.1rem; line-height: 1.6; color: var(--accents-8);" /> : (project.body ? <PortableText portableText={project.body} /> : <p>No content available.</p>)}
    </section>

    {nextProject && (
      <footer class="magazine-footer-nav">
        <a href={`/projects/${nextProject.slug.current}`} class="footer-nav-link" data-hover style="text-align: right; width: 100%;">
          <span class="nav-label">NEXT PROJECT</span>
          {nextProject.title}
        </a>
      </footer>
    )}
    <a href="/#top" class="footer-back-studio" data-hover>&larr; Back to Studio Index</a>
  </article>
</MagazineLayout>
