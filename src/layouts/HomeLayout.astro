---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
  projects?: any[];
}

const { title, description = "Svazer The Great - Digital Ecosystem", projects = [] } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Lucide Icons -->
    <script is:inline src="https://unpkg.com/lucide@0.460.0"></script>

    <!-- GSAP & ScrollTrigger -->
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollToPlugin.min.js"></script>

    <ClientRouter />
  </head>
  <body>
    <!-- Custom Cursor -->
    <div class="custom-cursor" transition:persist></div>

    <!-- Global Anchor -->
    <a href="#top" class="global-anchor" data-hover>
      <span>SVAZER</span>
      <span class="anchor-sub">THE GREAT</span>
    </a>

    <header class="site-header">
      <div class="header-inner">
        <nav class="nav-links">
          <a href="/" class="nav-link" data-hover>Studio</a>
          <a href="/logbook" class="nav-link" data-hover>Logbook</a>
          <a href="/resume" class="nav-link" data-hover>Resume</a>
        </nav>
        <!-- Mobile Hamburger Button -->
        <button class="hamburger-btn" aria-label="Toggle menu">
          <div class="hamburger-box">
            <div class="hamburger-line"></div>
            <div class="hamburger-line"></div>
            <div class="hamburger-line"></div>
          </div>
        </button>
      </div>
    </header>

    <!-- Full-Screen Hamburger Menu Overlay -->
    <div class="mobile-menu-overlay">
      <nav class="mobile-nav-links">
        <a href="/" class="mobile-nav-link">Studio</a>
        <a href="/logbook" class="mobile-nav-link">Logbook</a>
        <a href="/resume" class="mobile-nav-link">Resume</a>
      </nav>
      <div class="mobile-menu-footer">
        <div class="mobile-socials">
          <a href="https://github.com/svazerID" target="_blank" rel="noreferrer">GITHUB</a>
          <a href="https://www.instagram.com/rdnmshtguy" target="_blank" rel="noreferrer">INSTAGRAM</a>
        </div>
      </div>
    </div>

    <!-- Dot Navigation -->
    <div class="dot-nav">
      <div class="dot active" data-target="#top"></div>
      {projects.map((_, i) => (
        <div class="dot" data-target={`#app-${i}`}></div>
      ))}
      <div class="dot" data-target="#design-system"></div>
      <div class="dot" data-target="#logbook"></div>
      <div class="dot" data-target="#shelf-builds"></div>
      <div class="dot" data-target="#shelf-media"></div>
    </div>

    <div class="layout">
      <main class="snap-container">
        <slot />
      </main>
    </div>

    <script is:inline src="/script.js"></script>
  </body>
</html>
